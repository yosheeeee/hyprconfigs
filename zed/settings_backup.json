// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette
{
  "cursor_shape": "bar",
  "notification_panel": {
    "button": false
  },
  "git_panel": {
    "button": false
  },
  "outline_panel": {
    "button": false
  },
  "use_system_window_tabs": false,
  "bottom_dock_layout": "contained",
  "preview_tabs": {
    "enable_preview_from_code_navigation": true,
    "enable_preview_from_file_finder": true,
    "enabled": true
  },
  "tabs": {
    "file_icons": true,
    "git_status": false
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show": true
  },
  "title_bar": {
    "show_menus": false,
    "show_user_picture": true,
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_branch_icon": true
  },
  "debugger": {
    "button": false
  },
  "search": {
    "button": false
  },
  "diagnostics": {
    "button": true
  },
  "terminal": {
    "dock": "bottom",
    "button": true
  },
  "status_bar": {
    "cursor_position_button": true
  },
  "project_panel": {
    "auto_reveal_entries": true,
    "entry_spacing": "comfortable",
    "button": true
  },
  "unnecessary_code_fade": 0.30000001192092896,
  "show_edit_predictions": false,
  "icon_theme": "Catppuccin Frappé",
  "agent": {
    "default_model": {
      "provider": "google",
      "model": "gemini-3-pro-preview"
    },
    "model_parameters": []
  },
  "agent_servers": {
    "qwen": {
      "command": "qwen",
      "args": ["--experimental-acp"],
      "env": {}
    }
  },

  "ssh_connections": [
    {
      "host": "192.168.0.113",
      "username": "admin",
      "args": ["-i", "~/.ssh/known-hosts"],
      "nickname": "local server"
    }
  ],
  "features": {
    "edit_prediction_provider": "zed"
  },
  "git": {
    "git_gutter": "hide",
    "inline_blame": {
      "enabled": false
    }
  },
  "scrollbar": {
    "show": "never"
  },
  "relative_line_numbers": "enabled",
  "cursor_blink": true,
  "cursor_blink_animation": "fade",
  "ui_font_size": 19.0,
  "buffer_font_size": 24.0,
  "base_keymap": "VSCode",
  "ui_font_family": "Iosevka Nerd Font",
  "buffer_font_family": "Iosevka Nerd Font",
  "buffer_font_weight": 600,
  "buffer_line_height": "comfortable",
  "buffer_font_features": {
    "calt": true
  },
  "inlay_hints": {
    "enabled": true
  },
  "theme": "Base16 Ayu Dark",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
    "active_line_width": 2
  },
  "vim_mode": true
}
